{
  "expo": {
    "name": "OptaJob",
    "slug": "optajob",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e2550"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e2550"
      },
      "package": "com.udittandon.optajob",
      "versionCode": 1,
      "targetSdkVersion": 35,
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-notifications",
      "react-native-google-mobile-ads"
    ],
    "extra": {
      "eas": {
        "projectId": "5d8e548c-b69e-4ffd-b21d-ed28b5fc041a"
      }
    },
    "owner": "udit2k7"
  }
}
